<Window x:Class="Knapsack.DesktopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:vm="clr-namespace:Knapsack.DesktopApp.ViewModels"
        mc:Ignorable="d"
        Title="Mochila 0/1 - Analisador" Height="760" Width="1180"
        Background="#F4F6F8" WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="Label">
            <Setter Property="Margin" Value="0,8,0,2" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#37474F" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Margin" Value="0,0,0,2" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Background" Value="#1976D2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1565C0" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#B0BEC5" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="10" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="FontSize" Value="13" />
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Cabecalho -->
        <Border DockPanel.Dock="Top" Background="#0D47A1" Padding="16,12">
            <StackPanel>
                <TextBlock Text="Analisador da Mochila 0/1" Foreground="White"
                           FontSize="20" FontWeight="Bold" />
                <TextBlock Text="Compare os algoritmos Exato, Programacao Dinamica e Guloso"
                           Foreground="#BBDEFB" FontSize="12" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- Barra de status -->
        <Border DockPanel.Dock="Bottom" Background="#ECEFF1" Padding="12,6"
                BorderBrush="#CFD8DC" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Status:" FontWeight="SemiBold" Margin="0,0,6,0" />
                <TextBlock Text="{Binding StatusMessage}" />
            </StackPanel>
        </Border>

        <!-- Painel de parametros (esquerda) -->
        <Border DockPanel.Dock="Left" Width="280" Background="White"
                BorderBrush="#CFD8DC" BorderThickness="0,0,1,0"
                IsEnabled="{Binding NotBusy}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="14">
                <StackPanel>
                    <GroupBox Header="Parametros da instancia">
                        <StackPanel>
                            <TextBlock Text="Quantidade de itens" Style="{StaticResource Label}" />
                            <TextBox Text="{Binding ItemCount}" />

                            <TextBlock Text="Peso minimo / maximo" Style="{StaticResource Label}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding MinWeight}" />
                                <TextBox Grid.Column="2" Text="{Binding MaxWeight}" />
                            </Grid>

                            <TextBlock Text="Utilidade minima / maxima" Style="{StaticResource Label}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding MinUtility}" />
                                <TextBox Grid.Column="2" Text="{Binding MaxUtility}" />
                            </Grid>

                            <TextBlock Text="Modo de capacidade" Style="{StaticResource Label}" />
                            <ComboBox ItemsSource="{Binding CapacityModes}"
                                      SelectedItem="{Binding SelectedCapacityMode}" />

                            <CheckBox Content="Usar seed fixa" IsChecked="{Binding UseSeed}"
                                      Margin="0,10,0,0" />
                            <TextBox Text="{Binding SeedValue}" IsEnabled="{Binding UseSeed}"
                                     Margin="0,4,0,0" />

                            <Button Content="Gerar instancia" Command="{Binding GenerateInstanceCommand}" />
                            <Button Content="Carregar JSON" Command="{Binding LoadInstanceCommand}"
                                    Background="#455A64" />
                            <Button Content="Salvar JSON" Command="{Binding SaveInstanceCommand}"
                                    Background="#455A64" />
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Experimentos (escalabilidade)">
                        <StackPanel>
                            <TextBlock Text="n inicial / final" Style="{StaticResource Label}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding ExpStartN}" />
                                <TextBox Grid.Column="2" Text="{Binding ExpEndN}" />
                            </Grid>

                            <TextBlock Text="Passo / repeticoes" Style="{StaticResource Label}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{Binding ExpStep}" />
                                <TextBox Grid.Column="2" Text="{Binding ExpRepetitions}" />
                            </Grid>

                            <TextBlock Text="Modo de capacidade" Style="{StaticResource Label}" />
                            <ComboBox ItemsSource="{Binding CapacityModes}"
                                      SelectedItem="{Binding ExpCapacityMode}" />

                            <Button Content="Rodar experimentos" Command="{Binding RunExperimentsCommand}" />
                            <Button Content="Exportar CSV" Command="{Binding ExportCsvCommand}"
                                    Background="#2E7D32" />
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Conteudo principal -->
        <TabControl Margin="12" Background="Transparent" BorderThickness="0">

            <!-- Aba: Instancia -->
            <TabItem Header="Instancia">
                <DockPanel Margin="0,8,0,0">
                    <Border DockPanel.Dock="Top" Background="#E3F2FD" Padding="10" CornerRadius="4"
                            Margin="0,0,0,8">
                        <TextBlock Text="{Binding InstanceSummary}" FontWeight="SemiBold" />
                    </Border>
                    <DataGrid ItemsSource="{Binding InstanceItems}" AutoGenerateColumns="False"
                              IsReadOnly="True" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              RowBackground="White" AlternatingRowBackground="#F5F5F5">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="60" />
                            <DataGridTextColumn Header="Peso" Binding="{Binding Weight}" Width="*" />
                            <DataGridTextColumn Header="Utilidade" Binding="{Binding Utility}" Width="*" />
                            <DataGridTextColumn Header="Util/Peso" Binding="{Binding Ratio, StringFormat=F3}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <!-- Aba: Comparar -->
            <TabItem Header="Comparar">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button Grid.Row="0" Content="Executar todos os algoritmos"
                            Command="{Binding RunAllCommand}" HorizontalAlignment="Left"
                            Padding="14,8" />

                    <DataGrid Grid.Row="1" ItemsSource="{Binding AlgorithmRows}" AutoGenerateColumns="False"
                              IsReadOnly="True" HeadersVisibility="Column" Margin="0,10,0,10"
                              GridLinesVisibility="Horizontal" RowBackground="White"
                              AlternatingRowBackground="#F5F5F5" MaxHeight="180">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Algoritmo" Binding="{Binding Algorithm}" Width="2*" />
                            <DataGridTextColumn Header="Utilidade" Binding="{Binding Utility}" Width="*" />
                            <DataGridTextColumn Header="Peso" Binding="{Binding Weight}" Width="*" />
                            <DataGridTextColumn Header="Tempo (ms)" Binding="{Binding ElapsedMs, StringFormat=F3}" Width="*" />
                            <DataGridTextColumn Header="Dif. otimo" Binding="{Binding DiffToOptimal}" Width="*" />
                            <DataGridTextColumn Header="Qualidade" Binding="{Binding Quality}" Width="*" />
                        </DataGrid.Columns>
                    </DataGrid>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" CornerRadius="4" Margin="0,0,6,0" Padding="8">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Utilidade por algoritmo"
                                           FontWeight="SemiBold" Margin="4,0,0,6" />
                                <lvc:CartesianChart Series="{Binding UtilitySeries}"
                                                    XAxes="{Binding UtilityXAxes}"
                                                    LegendPosition="Bottom" />
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="1" Background="White" CornerRadius="4" Margin="6,0,0,0" Padding="8">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Tempo de execucao (ms)"
                                           FontWeight="SemiBold" Margin="4,0,0,6" />
                                <lvc:CartesianChart Series="{Binding TimeSeries}"
                                                    XAxes="{Binding TimeXAxes}"
                                                    LegendPosition="Bottom" />
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Aba: Experimentos -->
            <TabItem Header="Experimentos / Escalabilidade">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FFF3E0" Padding="10" CornerRadius="4" Margin="0,0,0,8">
                        <TextBlock TextWrapping="Wrap"
                                   Text="Varia o numero de itens (n) e mede o tempo medio e o erro relativo medio de cada algoritmo. Configure os parametros no painel a esquerda e clique em 'Rodar experimentos'." />
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="White" CornerRadius="4" Margin="0,0,6,0" Padding="8">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Tempo medio (ms) x n"
                                           FontWeight="SemiBold" Margin="4,0,0,6" />
                                <lvc:CartesianChart Series="{Binding TimeVsNSeries}"
                                                    XAxes="{Binding TimeVsNXAxes}"
                                                    LegendPosition="Bottom" />
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="1" Background="White" CornerRadius="4" Margin="6,0,0,0" Padding="8">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Erro relativo medio (%) x n"
                                           FontWeight="SemiBold" Margin="4,0,0,6" />
                                <lvc:CartesianChart Series="{Binding ErrorVsNSeries}"
                                                    XAxes="{Binding ErrorVsNXAxes}"
                                                    LegendPosition="Bottom" />
                            </DockPanel>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Aba: Testes -->
            <TabItem Header="Testes">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#E8F5E9" Padding="12" CornerRadius="4" Margin="0,0,0,8">
                        <TextBlock Text="{Binding TestExplanation}" TextWrapping="Wrap" Foreground="#1B5E20" />
                    </Border>

                    <Button Grid.Row="1" Content="Rodar testes" Command="{Binding RunTestsCommand}"
                            IsEnabled="{Binding NotBusy}" HorizontalAlignment="Left" Padding="14,8"
                            Background="#2E7D32" />

                    <TextBlock Grid.Row="2" Text="{Binding TestSummary}" FontWeight="Bold"
                               Margin="0,10,0,6" />

                    <Border Grid.Row="3" Background="#1E1E1E" CornerRadius="4">
                        <TextBox Text="{Binding TestOutput, Mode=OneWay}" IsReadOnly="True"
                                 Background="#1E1E1E" Foreground="#D4D4D4" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="12"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap" Padding="8" />
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
